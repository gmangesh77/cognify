# Cognify Configuration
# All vars prefixed with COGNIFY_
# List values use JSON array format (pydantic-settings JSON parsing)
#
# Copy this file to .env and fill in values:
#   cp .env.example .env

# ── Core ──────────────────────────────────────────────────────────
COGNIFY_DEBUG=true
COGNIFY_LOG_LEVEL=DEBUG
COGNIFY_CORS_ALLOWED_ORIGINS=["http://localhost:3000"]
COGNIFY_RATE_LIMIT_DEFAULT=100/minute

# ── Database (PostgreSQL) ─────────────────────────────────────────
# Required for persistent storage. Without this, the app uses in-memory repos.
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<db>
# Must match the credentials in docker-compose.yml.
COGNIFY_DATABASE_URL=postgresql+asyncpg://cognify:cognify@localhost:5432/cognify

# ── JWT Authentication ────────────────────────────────────────────
# Generate keys: openssl genrsa 2048 > private.pem && openssl rsa -in private.pem -pubout > public.pem
# Then paste the contents here (multiline values must be quoted).
COGNIFY_JWT_PRIVATE_KEY=  # RSA private key PEM
COGNIFY_JWT_PUBLIC_KEY=   # RSA public key PEM
COGNIFY_JWT_ALGORITHM=RS256
COGNIFY_JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
COGNIFY_JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Encryption ──────────────────────────────────────────────────
# Fernet key for encrypting API keys at rest in PostgreSQL.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If not set, an ephemeral key is auto-generated (keys will be lost on restart).
# COGNIFY_ENCRYPTION_KEY=

# ── LLM / AI ─────────────────────────────────────────────────────
# Anthropic API key (required for real article generation via INFRA-003)
# COGNIFY_ANTHROPIC_API_KEY=

# OpenAI API key (required for DALL-E illustration generation)
# COGNIFY_OPENAI_API_KEY=

# Model names (for provenance tracking)
# COGNIFY_PRIMARY_MODEL_NAME=claude-sonnet-4
# COGNIFY_DRAFTING_MODEL_NAME=claude-sonnet-4

# ── Vector Database (Milvus) ─────────────────────────────────────
# Docker (recommended): http://localhost:19530 (run: docker compose up -d)
# Milvus Lite (Linux/macOS only): ./milvus_data.db
COGNIFY_MILVUS_URI=http://localhost:19530
# COGNIFY_EMBEDDING_MODEL=all-MiniLM-L6-v2
# COGNIFY_CHUNK_SIZE_TOKENS=512
# COGNIFY_TOP_K_RETRIEVAL=5

# ── External API Keys (Trend Sources & Research) ─────────────────
# SerpAPI — web search for research agents
# COGNIFY_SERPAPI_API_KEY=

# Semantic Scholar — academic paper search (optional, higher rate limits)
# COGNIFY_SEMANTIC_SCHOLAR_API_KEY=

# NewsAPI — mainstream news headlines
# COGNIFY_NEWSAPI_API_KEY=

# Reddit — community trending topics (OAuth2)
# COGNIFY_REDDIT_CLIENT_ID=
# COGNIFY_REDDIT_CLIENT_SECRET=

# ── Visual Assets ─────────────────────────────────────────────────
# COGNIFY_CHART_OUTPUT_DIR=generated_assets/charts
# COGNIFY_ILLUSTRATION_OUTPUT_DIR=generated_assets/illustrations
# COGNIFY_DIAGRAM_OUTPUT_DIR=generated_assets/diagrams
